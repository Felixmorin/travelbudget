NEXT_PUBLIC_SITE_URL=https://travelbudget.ai

# Optional affiliate provider overrides. Defaults use Skyscanner for flights,
# Booking.com for hotels, Airalo for eSIM, and GetYourGuide for activities.
NEXT_PUBLIC_FLIGHTS_AFFILIATE_BASE_URL=https://www.skyscanner.ca/transport/flights/
NEXT_PUBLIC_FLIGHTS_AFFILIATE_QUERY_PARAM=query
NEXT_PUBLIC_FLIGHTS_AFFILIATE_PROVIDER=Skyscanner
NEXT_PUBLIC_FLIGHTS_AFFILIATE_PARTNER=Skyscanner
NEXT_PUBLIC_BOOKING_AFFILIATE_AID=
NEXT_PUBLIC_ESIM_AFFILIATE_BASE_URL=https://www.airalo.com/search
NEXT_PUBLIC_ESIM_AFFILIATE_QUERY_PARAM=search
NEXT_PUBLIC_ACTIVITIES_AFFILIATE_BASE_URL=https://www.getyourguide.com/s/
NEXT_PUBLIC_ACTIVITIES_AFFILIATE_QUERY_PARAM=q

# Optional development logging for email capture leads. Do not put provider API keys in code.
LEAD_CAPTURE_LOG_TO_CONSOLE=false

# Required in production for lead capture. Point this at your CRM, database API,
# email automation tool, or server-side webhook receiver.
LEAD_CAPTURE_WEBHOOK_URL=
LEAD_CAPTURE_WEBHOOK_SECRET=
