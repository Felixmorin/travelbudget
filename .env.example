NEXT_PUBLIC_SITE_URL=https://gobybudget.com

# Analytics. Set one or more production IDs before launch.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/script.js
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_TRAVELPAYOUTS_DRIVE_SCRIPT_SRC=
NEXT_PUBLIC_GOOGLE_ADS_CLIENT_ID=

# Private SEO agent for Google Search Console + GA4 recommendations.
# Protect /api/admin/seo-agent with a long random token.
SEO_AGENT_ADMIN_TOKEN=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://gobybudget.com/
GA4_PROPERTY_ID=
# Required only when enabling Vercel Cron for /api/cron/seo-workers.
CRON_SECRET=

# Public affiliate entry links. These are outbound partner URLs, not secret API tokens.
NEXT_PUBLIC_AVIASALES_AFFILIATE_URL=https://aviasales.tpx.lu/59DXH0n1
NEXT_PUBLIC_BOOKING_AFFILIATE_URL=[[COLLE_ICI_TON_LIEN_BOOKING_COM]]
NEXT_PUBLIC_GETYOURGUIDE_AFFILIATE_URL=https://www.getyourguide.com/?partner_id=4ZWE6DU&utm_medium=online_publisher
NEXT_PUBLIC_AIRALO_AFFILIATE_URL=https://airalo.tpx.lu/dj9PTkYV
NEXT_PUBLIC_DISCOVER_CARS_AFFILIATE_URL=[[COLLE_ICI_TON_LIEN_DISCOVER_CARS]]
NEXT_PUBLIC_OMIO_AFFILIATE_URL=[[COLLE_ICI_TON_LIEN_OMIO]]
NEXT_PUBLIC_TRAVEL_INSURANCE_AFFILIATE_URL=[[COLLE_ICI_TON_LIEN_ASSURANCE_VOYAGE]]
NEXT_PUBLIC_AIRPORT_TRANSFER_AFFILIATE_URL=https://kiwitaxi.tpx.lu/yLIGDtS4

# Optional Aviasales deep-link marker. Public affiliate marker only, not an API token.
NEXT_PUBLIC_AVIASALES_FALLBACK_URL=https://aviasales.tpx.lu/59DXH0n1
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=

# Server-side redirect whitelist for /go. Defaults include Aviasales,
# Travelpayouts short links, Booking, Airalo, GetYourGuide, Discover Cars, Omio, Kiwitaxi, and Skyscanner.
AFFILIATE_ALLOWED_DOMAINS=aviasales.com,tpx.lu,booking.com,airalo.com,getyourguide.com,discovercars.com,omio.com,kiwitaxi.com,skyscanner.ca,skyscanner.com

# Server-only Travelpayouts values. Keep these empty unless a server API integration is added.
TRAVELPAYOUTS_API_TOKEN=
TRAVELPAYOUTS_MARKER=

# Lightweight backend for analytics, leads, affiliate click tracking, and the first
# authenticated saved-trip data model. Apply docs/supabase/migrations in lexical order.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# Test-only escape hatch for Playwright/dev smoke tests. Do not set in production.
SUPABASE_STORAGE_MODE=

# Optional production API monitoring. Logs always go to server console;
# this webhook receives structured error/warn/info payloads when configured.
API_LOG_LEVEL=warn
MONITORING_WEBHOOK_URL=
MONITORING_WEBHOOK_SECRET=

# Production incident alerting fallback when no webhook destination is used.
# Set both provider and escalation target so /api/health can confirm launch alerting.
INCIDENT_ALERTING_PROVIDER=
INCIDENT_ALERTING_ESCALATION_TARGET=
INCIDENT_ALERTING_RUNBOOK_URL=
